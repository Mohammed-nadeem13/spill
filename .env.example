# Primary provider — Google Gemini API (free tier key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback provider — OpenRouter (https://openrouter.ai/keys)
# Used automatically if Gemini is rate-limited. Either provider alone is enough.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free
